PIPELINE_VERSION=1.0.0

# Entorno
ENV=dev
STAGE=dev
DEBUG=False
LOG_LEVEL=INFO

#Docker Image
IMAGE_VERSION=1.0.0
IMAGE_NAME=renovacion_prestamo-image
DOCKER_FASTAPI_NAME=renovacion_prestamo-api
DOCKER_MLFLOW_NAME=renovacion_prestamo-mlflow

# API
APP_NAME=Renovacion_Prestamo-Sinhue
APP_VERSION=1.0.0
APP_NETWORK_NAME=renovacion_prestamo-net
PORT_LOCAL=8085
PORT_REMOTE=8000

# MLflow
PIPELINE_VERSION=1.0.0
MLFLOW_PORT=5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_URI_DOCKER=http://0.0.0.0:5000
MLFLOW_EXPERIMENT=renovacion_prestamo-sinhue

# Modelo
MODEL_VERSION=latest
MODEL_NAME=RenovacionPrestamo
UMBRAL_MIN=0.60

#DVC
DVC_REMOTE_CREDENTIALS=DVC_REMOTE_CREDENTIALS

# Seguridad para GitHub Actions
SECRET_KEY=pendiente